<policies>
    <inbound>
        <base />
        <set-header name="X-Request-ID" exists-action="skip">
            <value>@(context.RequestId.ToString())</value>
        </set-header>
        <!-- SF JWT tokens use org-specific issuer/audience (instance URL, not login.salesforce.com).
             The kid is also org-specific, so OIDC discovery must point at the instance URL. -->
        <validate-jwt header-name="Authorization"
            failed-validation-httpcode="401"
            failed-validation-error-message="Unauthorized"
            require-scheme="Bearer">
            <openid-config url="{{SfInstanceUrl}}/.well-known/openid-configuration" />
            <audiences>
                <audience>{{SfInstanceUrl}}</audience>
            </audiences>
            <issuers>
                <issuer>{{SfInstanceUrl}}</issuer>
            </issuers>
        </validate-jwt>
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
        <choose>
            <when condition="@(context.Response.StatusCode == 401)">
                <return-response>
                    <set-status code="401" reason="Unauthorized" />
                    <set-header name="WWW-Authenticate" exists-action="override">
                        <value>Bearer error="invalid_token", resource_metadata="{{APIMGatewayURL}}/salesforce-mcp/.well-known/oauth-protected-resource"</value>
                    </set-header>
                </return-response>
            </when>
        </choose>
    </on-error>
</policies>
